  "dialogues": {
    "mayor": {
      "greeting": {
        "id": "mayor_greeting",
        "priority": 0,
        "conditions": [],
        "lines": [
          {"speaker": "镇长托马斯", "text": "欢迎来到我们美丽的村庄！"},
          {"speaker": "镇长托马斯", "text": "我是镇长托马斯，很高兴认识你。"},
          {"speaker": "镇长托马斯", "text": "这个村庄虽然不大，但住着一群善良的人们。"},
          {"speaker": "镇长托马斯", "text": "如果你需要帮助，随时可以找我。"}
        ]
      },
      "first_meeting": {
        "id": "mayor_first_meeting",
        "priority": 100,
        "conditions": [
          {"type": "flag", "key": "met_mayor", "value": false}
        ],
        "lines": [
          {"speaker": "镇长托马斯", "text": "哦！你一定是新来的农场主！"},
          {"speaker": "镇长托马斯", "text": "我听说了你要接手那座旧农场的事。"},
          {"speaker": "镇长托马斯", "text": "那是你祖父留下的宝贵财产，希望你能好好经营它。"},
          {
            "speaker": "镇长托马斯",
            "text": "你以前有务农经验吗？",
            "choices": [
              {"text": "有的，我从小就帮忙干农活", "next": "experienced"},
              {"text": "没有，但我愿意学习", "next": "newcomer"}
            ]
          }
        ],
        "branches": {
          "experienced": {
            "lines": [
              {"speaker": "镇长托马斯", "text": "太好了！那我就放心了。"},
              {"speaker": "镇长托马斯", "text": "相信你一定能让那座农场重现往日的辉煌！"}
            ],
            "effects": [
              {"type": "set_flag", "key": "met_mayor", "value": true},
              {"type": "add_friendship", "npc": "mayor", "amount": 50}
            ]
          },
          "newcomer": {
            "lines": [
              {"speaker": "镇长托马斯", "text": "别担心，万事开头难。"},
              {"speaker": "镇长托马斯", "text": "我们村的约翰老兄是个种田的好手，你可以向他请教。"},
              {"speaker": "镇长托马斯", "text": "只要肯努力，一定会有收获的！"}
            ],
            "effects": [
              {"type": "set_flag", "key": "met_mayor", "value": true},
              {"type": "set_flag", "key": "can_meet_farmer", "value": true}
            ]
          }
        }
      },
      "morning": {
        "id": "mayor_morning",
        "priority": 10,
        "conditions": [
          {"type": "time", "min": 6.0, "max": 12.0},
          {"type": "flag", "key": "met_mayor", "value": true}
        ],
        "lines": [
          {"speaker": "镇长托马斯", "text": "早上好啊！今天天气真不错。"},
          {"speaker": "镇长托马斯", "text": "适合在田里干活的天气呢。"}
        ]
      },
      "afternoon": {
        "id": "mayor_afternoon",
        "priority": 10,
        "conditions": [
          {"type": "time", "min": 12.0, "max": 18.0},
          {"type": "flag", "key": "met_mayor", "value": true}
        ],
        "lines": [
          {"speaker": "镇长托马斯", "text": "下午好！忙了一天了吗？"},
          {"speaker": "镇长托马斯", "text": "记得要劳逸结合，不要太累着自己。"}
        ]
      },
      "evening": {
        "id": "mayor_evening",
        "priority": 10,
        "conditions": [
          {"type": "time", "min": 18.0, "max": 26.0},
          {"type": "flag", "key": "met_mayor", "value": true}
        ],
        "lines": [
          {"speaker": "镇长托马斯", "text": "晚上好！这么晚还在外面忙？"},
          {"speaker": "镇长托马斯", "text": "早点回去休息吧，明天还有很多事要做。"}
        ]
      },
      "spring_festival": {
        "id": "mayor_spring_festival",
        "priority": 50,
        "conditions": [
          {"type": "season", "value": "spring"},
          {"type": "day", "value": 15}
        ],
        "lines": [
          {"speaker": "镇长托马斯", "text": "欢迎参加春季花祭！"},
          {"speaker": "镇长托马斯", "text": "这是我们村最重要的节日之一。"},
          {"speaker": "镇长托马斯", "text": "希望大家都能玩得开心！"}
        ]
      }
    },
    "farmer": {
      "greeting": {
        "id": "farmer_greeting",
        "priority": 0,
        "conditions": [],
        "lines": [
          {"speaker": "农场主约翰", "text": "你好，年轻人！"},
          {"speaker": "农场主约翰", "text": "有什么农事方面的问题可以问我。"}
        ]
      },
      "tutorial_watering": {
        "id": "farmer_tutorial_watering",
        "priority": 80,
        "conditions": [
          {"type": "flag", "key": "need_watering_tutorial", "value": true}
        ],
        "lines": [
          {"speaker": "农场主约翰", "text": "看来你需要学习如何浇水。"},
          {"speaker": "农场主约翰", "text": "浇水是种植中最基本的工作之一。"},
          {"speaker": "农场主约翰", "text": "每天早上都要给作物浇水，否则它们就无法生长。"},
          {"speaker": "农场主约翰", "text": "使用水壶站在耕地旁边按住使用键就可以了。"},
          {"speaker": "农场主约翰", "text": "记住，只有浇过水的土地才能让作物茁壮成长！"}
        ],
        "effects": [
          {"type": "set_flag", "key": "need_watering_tutorial", "value": false},
          {"type": "set_flag", "key": "watering_tutorial_done", "value": true}
        ]
      },
      "crop_advice": {
        "id": "farmer_crop_advice",
        "priority": 20,
        "conditions": [
          {"type": "flag", "key": "watering_tutorial_done", "value": true},
          {"type": "friendship", "npc": "farmer", "min": 1}
        ],
        "lines": [
          {"speaker": "农场主约翰", "text": "想听点种田的小窍门吗？"},
          {
            "speaker": "农场主约翰",
            "text": "什么方面的建议呢？",
            "choices": [
              {"text": "关于种子选择", "next": "seed_advice"},
              {"text": "关于浇水技巧", "next": "water_advice"},
              {"text": "关于收获时机", "next": "harvest_advice"}
            ]
          }
        ],
        "branches": {
          "seed_advice": {
            "lines": [
              {"speaker": "农场主约翰", "text": "选择种子要看季节和你的资金。"},
              {"speaker": "农场主约翰", "text": "芜菁种子便宜，适合新手练手。"},
              {"speaker": "农场主约翰", "text": "南瓜虽然贵，但利润也最高！"}
            ]
          },
          "water_advice": {
            "lines": [
              {"speaker": "农场主约翰", "text": "每天都要浇水，但下雨天例外。"},
              {"speaker": "农场主约翰", "text": "如果忘记浇水，作物会停止生长一天。"},
              {"speaker": "农场主约翰", "text": "建议早上第一件事就是浇水！"}
            ]
          },
          "harvest_advice": {
            "lines": [
              {"speaker": "农场主约翰", "text": "作物成熟后要及时收获。"},
              {"speaker": "农场主约翰", "text": "品质越高的作物卖价越好。"},
              {"speaker": "农场主约翰", "text": "多浇几天水可能会提升品质哦！"}
            ]
          }
        }
      }
    },
    "merchant": {
      "greeting": {
        "id": "merchant_greeting",
        "priority": 0,
        "conditions": [],
        "lines": [
          {"speaker": "商人艾米丽", "text": "欢迎光临！"},
          {"speaker": "商人艾米丽", "text": "看看有什么喜欢的？"}
        ]
      },
      "buy_seeds": {
        "id": "merchant_buy_seeds",
        "priority": 30,
        "conditions": [
          {"type": "season", "value": "spring"}
        ],
        "lines": [
          {"speaker": "商人艾米丽", "text": "春天到了！"},
          {"speaker": "商人艾米丽", "text": "我们有新鲜的芜菁种子和土豆种子。"},
          {"speaker": "商人艾米丽", "text": "芜菁生长快，土豆利润高，都很推荐哦！"}
        ]
      },
      "rare_items": {
        "id": "merchant_rare_items",
        "priority": 40,
        "conditions": [
          {"type": "friendship", "npc": "merchant", "min": 3}
        ],
        "lines": [
          {"speaker": "商人艾米丽", "text": "嘘...我有些特别的商品。"},
          {"speaker": "商人艾米丽", "text": "这是只给老顾客看的好东西。"},
          {
            "speaker": "商人艾米丽",
            "text": "你要看看吗？",
            "choices": [
              {"text": "当然！", "next": "show_items"},
              {"text": "下次吧", "next": "decline"}
            ]
          }
        ],
        "branches": {
          "show_items": {
            "lines": [
              {"speaker": "商人艾米丽", "text": "太好了！看这个..."},
              {"speaker": "商人艾米丽", "text": "稀有种子！只能在这里买到。"}
            ],
            "effects": [
              {"type": "unlock_shop", "shop": "rare_seeds"}
            ]
          },
          "decline": {
            "lines": [
              {"speaker": "商人艾米丽", "text": "好的，随时欢迎你回来。"}
            ]
          }
        }
      }
    },
    "blacksmith": {
      "greeting": {
        "id": "blacksmith_greeting",
        "priority": 0,
        "conditions": [],
        "lines": [
          {"speaker": "铁匠布鲁斯", "text": "有什么需要打造的吗？"},
          {"speaker": "铁匠布鲁斯", "text": "好的工具是干活的基础。"}
        ]
      },
      "upgrade_tool": {
        "id": "blacksmith_upgrade",
        "priority": 50,
        "conditions": [
          {"type": "flag", "key": "can_upgrade_tools", "value": true}
        ],
        "lines": [
          {"speaker": "铁匠布鲁斯", "text": "你的工具升级了吗？"},
          {"speaker": "铁匠布鲁斯", "text": "升级后的工具效率更高，范围更大。"},
          {"speaker": "铁匠布鲁斯", "text": "需要矿石和金钱来升级。"},
          {
            "speaker": "铁匠布鲁斯",
            "text": "想要升级哪个工具？",
            "choices": [
              {"text": "锄头", "next": "upgrade_hoe"},
              {"text": "水壶", "next": "upgrade_can"},
              {"text": "稍后再说", "next": "decline"}
            ]
          }
        ],
        "branches": {
          "upgrade_hoe": {
            "lines": [
              {"speaker": "铁匠布鲁斯", "text": "铜锄头需要5个铜矿石和500金币。"},
              {"speaker": "铁匠布鲁斯", "text": "升级后可以一次耕地三格。"}
            ],
            "effects": [
              {"type": "set_flag", "key": "upgrade_hoe_available", "value": true}
            ]
          },
          "upgrade_can": {
            "lines": [
              {"speaker": "铁匠布鲁斯", "text": "铜水壶需要5个铜矿石和500金币。"},
              {"speaker": "铁匠布鲁斯", "text": "升级后可以一次浇水三格。"}
            ],
            "effects": [
              {"type": "set_flag", "key": "upgrade_can_available", "value": true}
            ]
          },
          "decline": {
            "lines": [
              {"speaker": "铁匠布鲁斯", "text": "好的，随时来找我。"}
            ]
          }
        }
      }
    },
    "doctor": {
      "greeting": {
        "id": "doctor_greeting",
        "priority": 0,
        "conditions": [],
        "lines": [
          {"speaker": "医生玛丽", "text": "你好！身体健康吗？"},
          {"speaker": "医生玛丽", "text": "有任何不舒服都可以告诉我。"}
        ]
      },
      "low_energy": {
        "id": "doctor_low_energy",
        "priority": 60,
        "conditions": [
          {"type": "player_energy", "max": 20}
        ],
        "lines": [
          {"speaker": "医生玛丽", "text": "你看起来很疲惫！"},
          {"speaker": "医生玛丽", "text": "过度劳累对身体不好。"},
          {"speaker": "医生玛丽", "text": "要不要休息一下，或者吃点东西？"},
          {
            "speaker": "医生玛丽",
            "text": "我可以给你一些恢复体力的建议。",
            "choices": [
              {"text": "好的，谢谢", "next": "give_advice"},
              {"text": "我没事", "next": "decline_help"}
            ]
          }
        ],
        "branches": {
          "give_advice": {
            "lines": [
              {"speaker": "医生玛丽", "text": "食物可以恢复体力。"},
              {"speaker": "医生玛丽", "text": "面包和奶酪都是不错的选择。"},
              {"speaker": "医生玛丽", "text": "好好照顾自己！"}
            ],
            "effects": [
              {"type": "add_friendship", "npc": "doctor", "amount": 20}
            ]
          },
          "decline_help": {
            "lines": [
              {"speaker": "医生玛丽", "text": "好吧，但如果感觉不舒服要立刻休息。"}
            ]
          }
        }
      },
      "health_tip": {
        "id": "doctor_health_tip",
        "priority": 20,
        "conditions": [
          {"type": "friendship", "npc": "doctor", "min": 2}
        ],
        "lines": [
          {"speaker": "医生玛丽", "text": "要注意劳逸结合哦。"},
          {"speaker": "医生玛丽", "text": "体力用完了就需要休息或吃东西。"},
          {"speaker": "医生玛丽", "text": "如果体力耗尽继续工作，可能会晕倒！"}
        ]
      }
    }
  },
  "global_dialogues": {
    "intro": {
      "id": "game_intro",
      "trigger": "game_start",
      "lines": [
        {"speaker": "旁白", "text": "你来到了一个宁静的小村庄..."},
        {"speaker": "旁白", "text": "这里有一座等待你经营的旧农场。"},
        {"speaker": "旁白", "text": "新的生活即将开始..."}
      ],
      "effects": [
        {"type": "set_flag", "key": "game_started", "value": true},
        {"type": "trigger_dialogue", "npc": "mayor", "dialogue": "first_meeting"}
      ]
    },
    "day_start_spring": {
      "id": "day_start_spring",
      "trigger": "day_start",
      "conditions": [
        {"type": "season", "value": "spring"},
        {"type": "random", "chance": 0.3}
      ],
      "lines": [
        {"speaker": "旁白", "text": "春天的新一天开始了。"},
        {"speaker": "旁白", "text": "阳光明媚，正是耕作的好日子。"}
      ]
    },
    "rainy_day": {
      "id": "rainy_day",
      "trigger": "day_start",
      "conditions": [
        {"type": "weather", "value": "rain"}
      ],
      "lines": [
        {"speaker": "旁白", "text": "今天下着小雨。"},
        {"speaker": "旁白", "text": "不用浇水了，作物会自动被雨水滋润。"}
      ]
    }
  },
  "quest_dialogues": {
    "first_harvest": {
      "id": "quest_first_harvest",
      "trigger": "quest_start",
      "quest_id": "first_harvest",
      "lines": [
        {"speaker": "农场主约翰", "text": "太好了，你已经收获了第一批作物！"},
        {"speaker": "农场主约翰", "text": "收获的作物可以卖给商人换钱。"},
        {"speaker": "农场主约翰", "text": "或者留着做料理自己吃。"},
        {"speaker": "农场主约翰", "text": "你已经掌握了种植的基本技巧！"}
      ],
      "effects": [
        {"type": "complete_quest", "quest_id": "first_harvest"},
        {"type": "add_money", "amount": 100}
      ]
    },
    "expand_farm": {
      "id": "quest_expand_farm",
      "trigger": "quest_start",
      "quest_id": "expand_farm",
      "lines": [
        {"speaker": "镇长托马斯", "text": "听说你想要扩建农场？"},
        {"speaker": "镇长托马斯", "text": "这需要一定的资金和材料。"},
        {"speaker": "镇长托马斯", "text": "等你准备好了来找我。"},
        {
          "speaker": "镇长托马斯",
          "text": "扩建后你会有更多的土地可以耕种。",
          "choices": [
            {"text": "我想现在就扩建", "next": "expand_now", "conditions": [{"type": "money", "min": 1000}]},
            {"text": "我需要再准备一下", "next": "expand_later"}
          ]
        }
      ],
      "branches": {
        "expand_now": {
          "lines": [
            {"speaker": "镇长托马斯", "text": "太好了！明天就可以动工。"},
            {"speaker": "镇长托马斯", "text": "你的农场会变得更大更漂亮！"}
          ],
          "effects": [
            {"type": "remove_money", "amount": 1000},
            {"type": "set_flag", "key": "farm_expanded", "value": true},
            {"type": "complete_quest", "quest_id": "expand_farm"}
          ]
        },
        "expand_later": {
          "lines": [
            {"speaker": "镇长托马斯", "text": "好的，等你准备好了再来。"},
            {"speaker": "镇长托马斯", "text": "扩建需要1000金币。"}
          ]
        }
      }
    }
  }
}