; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Pastoral Tales"
config/description="A Stardew Valley style farming simulation RPG"
run/main_scene="res://src/ui/menus/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/bg_color=Color(0.141176, 0.141176, 0.141176, 1)

[autoload]

GameManager="*res://src/autoload/GameManager.gd"
TimeManager="*res://src/autoload/TimeManager.gd"
SaveManager="*res://src/autoload/SaveManager.gd"
EventBus="*res://src/autoload/EventBus.gd"
AudioManager="*res://src/autoload/AudioManager.gd"
InputManager="*res://src/autoload/InputManager.gd"
MoneySystem="*res://src/core/economy/MoneySystem.gd"
ShippingSystem="*res://src/core/economy/ShippingSystem.gd"
SceneTransition="*res://src/world/transitions/SceneTransition.gd"
ItemDatabase="*res://src/core/inventory/ItemDatabase.gd"
Inventory="*res://src/core/inventory/Inventory.gd"
GrowthSystem="*res://src/core/farming/GrowthSystem.gd"
GiftSystem="*res://src/core/social/GiftSystem.gd"
ForagingSystem="*res://src/core/farming/ForagingSystem.gd"
QuestSystem="*res://src/core/quest/QuestSystem.gd"
PlantingManager="*res://src/core/farming/PlantingManager.gd"
NPCManager="*res://src/core/relationship/NPCManager.gd"
HouseUpgradeSystem="*res://src/core/building/HouseUpgradeSystem.gd"
FurnitureDatabase="*res://src/core/building/FurnitureDatabase.gd"
FestivalSystem="*res://src/core/time/FestivalSystem.gd"
AchievementSystem="*res://src/core/achievement/AchievementSystem.gd"
SeasonSystem="*res://src/core/time/SeasonSystem.gd"
WeatherSystem="*res://src/core/weather/WeatherSystem.gd"
SleepSystem="*res://src/core/systems/SleepSystem.gd"
FishingSystem="*res://src/core/systems/FishingSystem.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

